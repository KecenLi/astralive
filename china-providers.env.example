# MODVII China-provider route template. Copy values into .env only after you have paid API keys.

# Recommended mixed route for China/Hong Kong network:
# - LLM/Vision: Alibaba Cloud Model Studio DashScope Hong Kong.
# - ASR/TTS fallback: SiliconFlow audio endpoints.
LLM_PROVIDER=openai_compatible
VISION_PROVIDER=openai_compatible
OPENAI_COMPATIBLE_BASE_URL=https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_API_KEY=PASTE_DASHSCOPE_API_KEY
OPENAI_COMPATIBLE_LLM_MODEL=qwen-plus
OPENAI_COMPATIBLE_VISION_MODEL=qwen-plus

ASR_PROVIDER=openai_compatible
TTS_PROVIDER=openai_compatible
REALTIME_PROVIDER=none
OPENAI_COMPATIBLE_ASR_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_COMPATIBLE_ASR_API_KEY=PASTE_SILICONFLOW_API_KEY
OPENAI_COMPATIBLE_ASR_MODEL=FunAudioLLM/SenseVoiceSmall
OPENAI_COMPATIBLE_ASR_ENDPOINT_PATH=/audio/transcriptions
OPENAI_COMPATIBLE_TTS_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_COMPATIBLE_TTS_API_KEY=PASTE_SILICONFLOW_API_KEY
OPENAI_COMPATIBLE_TTS_MODEL=fishaudio/fish-speech-1.5
OPENAI_COMPATIBLE_TTS_VOICE=default
OPENAI_COMPATIBLE_TTS_ENDPOINT_PATH=/audio/speech
OPENAI_COMPATIBLE_TTS_RESPONSE_FORMAT=mp3

# Alternative LLM/Vision base URLs:
# DashScope Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# Volcano Ark: https://ark.cn-beijing.volces.com/api/v3
# Baidu AI Studio/Qianfan: https://aistudio.baidu.com/llm/lmapi/v3
# SiliconFlow all-in-one: https://api.siliconflow.cn/v1
# Zhipu GLM: https://open.bigmodel.cn/api/paas/v4
# Tencent Hunyuan: https://api.hunyuan.cloud.tencent.com/v1
# Kimi: https://api.moonshot.ai/v1
# MiniMax: https://api.minimax.io/v1
# DeepSeek text-only cheap route: https://api.deepseek.com
