APP_ENV=development
APP_NAME=AstraLive

VITE_API_BASE_URL=http://127.0.0.1:8000
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
WEB_ORIGIN=http://localhost:5173

ASR_PROVIDER=mock
VISION_PROVIDER=mock
LLM_PROVIDER=mock
TTS_PROVIDER=mock
REALTIME_PROVIDER=none
GOOGLE_APPLICATION_CREDENTIALS=

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_LLM_MODEL=
OPENAI_COMPATIBLE_VISION_MODEL=
OPENAI_COMPATIBLE_TTS_MODEL=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash
GEMINI_ASR_MODEL=gemini-3.1-flash-live-preview
GEMINI_REALTIME_MODEL=gemini-3.1-flash-live-preview
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Kore

VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=global
VERTEX_AI_API_ENDPOINT=https://aiplatform.googleapis.com
VERTEX_AI_LLM_MODEL=gemini-2.5-flash
VERTEX_AI_VISION_MODEL=gemini-2.5-flash
VERTEX_AI_ASR_MODEL=gemini-live-2.5-flash-native-audio
VERTEX_AI_REALTIME_MODEL=gemini-live-2.5-flash-native-audio
VERTEX_AI_TTS_MODEL=gemini-3.1-flash-tts-preview
VERTEX_AI_TTS_VOICE=Kore

AUDIO_INPUT_SAMPLE_RATE=16000
AUDIO_OUTPUT_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
AUDIO_CHUNK_MAX_BYTES=262144
AUDIO_TURN_MAX_BYTES=2097152
AUDIO_TRANSCRIPTION_LANGUAGE=zh-CN
REALTIME_TURN_TIMEOUT_SECONDS=30

DASHSCOPE_API_KEY=
QWEN_LLM_MODEL=
QWEN_VISION_MODEL=
QWEN_REALTIME_MODEL=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen2.5:0.5b
LOCAL_ASR_MODEL_PATH=
LOCAL_TTS_MODEL_PATH=

VITE_LIVE2D_MODEL_URL=

WAKE_WORD=阿斯塔
FRAME_IDLE_FPS=0
FRAME_AWAKE_FPS=0.2
FRAME_ACTIVE_FPS=1
FRAME_JPEG_QUALITY=0.72
MAX_FRAME_WIDTH=1280
MAX_FRAME_HEIGHT=720
VISION_CACHE_TTL_SECONDS=30
SCENE_CHANGE_THRESHOLD=0.12
